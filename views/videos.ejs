<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Videos đã tạo</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,400,0,0" />
    <style>
      :root {
        --bg-dark: #1a1c1e;
        --card-bg: #212429;
        --border-color: #3f444c;
        --text-main: #e2e2e2;
        --text-dim: #9aa0a6;
        --accent-blue: #4d94ff;
        --accent-green: #4caf50;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: var(--bg-dark);
        color: var(--text-main);
        font-family: "Segoe UI", Roboto, sans-serif;
        min-height: 100vh;
        padding: 48px 20px;
      }
      .header {
        max-width: 1000px;
        margin: 0 auto 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
      }
      .header h1 { font-size: 24px; }
      .header-actions { display: flex; gap: 10px; align-items: center; }
      .btn {
        border: none;
        border-radius: 20px;
        padding: 8px 20px;
        font-size: 13px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: opacity 0.2s;
        text-decoration: none;
      }
      .btn:hover { opacity: 0.85; }
      .btn-back { background: #3f444c; color: var(--text-main); }
      .btn-dl-all { background: var(--accent-green); color: #fff; }
      .btn-dl-all:disabled { opacity: 0.4; cursor: not-allowed; }
      .empty {
        max-width: 1000px;
        margin: 80px auto;
        text-align: center;
        color: var(--text-dim);
      }
      .empty .material-symbols-outlined { font-size: 56px; margin-bottom: 12px; display: block; }
      .grid {
        max-width: 1000px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 16px;
      }
      .card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 14px;
        padding: 20px;
      }
      .card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 12px;
        gap: 8px;
      }
      .task-type {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 3px 10px;
        border-radius: 20px;
        background: #2d3748;
        color: var(--accent-blue);
      }
      .task-id { color: var(--text-dim); font-size: 12px; }
      .task-date { font-size: 12px; color: var(--text-dim); margin-bottom: 10px; }
      .task-prompt {
        font-size: 13px;
        color: var(--text-dim);
        margin-bottom: 14px;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
      }
      .video-list { display: flex; flex-direction: column; gap: 8px; }
      .video-item {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #131517;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 8px 12px;
        font-size: 12px;
      }
      .video-item .material-symbols-outlined { font-size: 18px; color: var(--accent-green); flex-shrink: 0; }
      .video-item span { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--text-dim); }
      .btn-dl {
        background: var(--accent-blue);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 4px 12px;
        font-size: 12px;
        cursor: pointer;
        white-space: nowrap;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
      }
      .btn-dl:hover { opacity: 0.85; }
      .no-videos {
        font-size: 13px;
        color: var(--text-dim);
        font-style: italic;
        padding: 8px 0;
      }
    </style>
  </head>
  <body>
    <% const allUrls = tasks.flatMap(t => t.videoUrls); %>
    <div class="header">
      <h1>
        <span class="material-symbols-outlined" style="vertical-align:middle; font-size:28px; color:var(--accent-green)">video_library</span>
        Videos đã tạo (<%= allUrls.length %>)
      </h1>
      <div class="header-actions">
        <button class="btn btn-dl-all" id="btnDlAll" onclick="downloadAll()" <%= allUrls.length === 0 ? 'disabled' : '' %>>
          <span class="material-symbols-outlined" style="font-size:16px">download</span>
          Tải tất cả (<%= allUrls.length %>)
        </button>
        <a href="/" class="btn btn-back">
          <span class="material-symbols-outlined" style="font-size:16px">arrow_back</span> Quay lại
        </a>
      </div>
    </div>

    <% if (tasks.length === 0) { %>
    <div class="empty">
      <span class="material-symbols-outlined">movie_off</span>
      <p>Chưa có video nào hoàn thành.</p>
      <p style="margin-top:6px; font-size:13px;">Tạo video rồi quay lại đây để tải về.</p>
    </div>
    <% } else { %>
    <div class="grid">
      <% tasks.forEach(task => { %>
      <div class="card">
        <div class="card-header">
          <span class="task-type"><%= task.type %></span>
          <span class="task-id">#<%= task.id %></span>
        </div>
        <div class="task-date">
          <span class="material-symbols-outlined" style="font-size:14px; vertical-align:middle">schedule</span>
          <%= new Date(task.doneAt).toLocaleString('vi-VN') %>
        </div>
        <%
          let promptPreview = '';
          if (task.type === 'text-to-video' && task.params.promptList?.length) {
            promptPreview = task.params.promptList[0];
          } else if (task.type === 'image-to-video' && task.params.tasks?.length) {
            promptPreview = task.params.tasks[0].prompt;
          } else if (task.type === 'ingredients-to-video' && task.params.ingredients?.length) {
            promptPreview = task.params.ingredients[0].prompt;
          }
        %>
        <% if (promptPreview) { %>
        <div class="task-prompt" title="<%= promptPreview %>"><%= promptPreview %></div>
        <% } %>

        <div class="video-list">
          <% if (task.videoUrls.length > 0) { %>
            <% task.videoUrls.forEach((url, i) => { %>
            <div class="video-item">
              <span class="material-symbols-outlined">videocam</span>
              <span title="<%= url %>">Video <%= i + 1 %></span>
              <a href="<%= url %>" download class="btn-dl">
                <span class="material-symbols-outlined" style="font-size:14px">download</span> Tải
              </a>
            </div>
            <% }) %>
          <% } else if (task.savedFiles.length > 0) { %>
            <% task.savedFiles.forEach((f, i) => { %>
            <div class="video-item">
              <span class="material-symbols-outlined">check_circle</span>
              <span title="<%= f %>"><%= f.split(/[\\/]/).pop() || 'Video ' + (i+1) %></span>
            </div>
            <% }) %>
          <% } else { %>
            <p class="no-videos">Chưa có link tải (đang chờ extension log URL)</p>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

    <script>
      const allVideoUrls = <%- JSON.stringify(tasks.flatMap(t => t.videoUrls)) %>;

      function downloadAll() {
        allVideoUrls.forEach((url, i) => {
          setTimeout(() => {
            const a = document.createElement('a');
            a.href = url;
            a.download = 'video_' + (i + 1) + '.mp4';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
          }, i * 800);
        });
      }
    </script>
  </body>
</html>