<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Google Flow - Frame Management</title>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,400,0,0"
    />
    <style>
      :root {
        --bg-dark: #1a1c1e;
        --card-bg: #212429;
        --border-color: #3f444c;
        --text-main: #e2e2e2;
        --text-dim: #9aa0a6;
        --accent-blue: #4d94ff;
      }

      body {
        background-color: var(--bg-dark);
        color: var(--text-main);
        font-family: "Segoe UI", Roboto, sans-serif;
        padding: 40px;
        display: flex;
        justify-content: center;
        box-sizing: border-box;
      }

      .container {
        max-width: 850px;
        width: 100%;
      }

      .bulk-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding: 0 10px;
      }

      .header-controls {
        display: flex;
        gap: 20px;
        align-items: center;
      }

      .btn-toggle-end {
        background: none;
        border: 1px solid var(--border-color);
        color: var(--text-main);
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
      }

      .btn-toggle-end:hover {
        background: #333;
      }

      .btn-clear {
        background: none;
        border: none;
        color: #ff6b6b;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 13px;
      }

      #flowList {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .frame-group {
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 20px;
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 15px;
      }

      .images-container {
        display: flex;
        align-items: center;
        gap: 15px;
      }

      .image-box {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .image-box span {
        font-size: 11px;
        color: var(--text-dim);
      }

      .thumbnail {
        width: 120px;
        height: 70px;
        border-radius: 8px;
        object-fit: cover;
        border: 1px solid var(--border-color);
        background: #000;
      }

      .arrow-sep {
        color: var(--text-dim);
      }

      .prompt-area {
        flex-grow: 1;
        background: #131517;
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 12px;
        height: 70px;
        color: #fff;
        font-size: 14px;
        resize: none;
      }

      .btn-delete {
        position: absolute;
        top: 15px;
        right: 15px;
        background: none;
        border: none;
        color: var(--text-dim);
        cursor: pointer;
      }

      /* LOGIC ẨN END FRAME */
      .hide-end .end-frame-box,
      .hide-end .arrow-sep {
        display: none !important;
      }

      .add-row {
        display: flex;
        justify-content: center;
        margin-top: 30px;
      }
      .btn-add-frame {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        border: 2px dashed var(--border-color);
        background: none;
        color: var(--text-dim);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .footer {
        margin-top: 40px;
        display: flex;
        justify-content: flex-end;
      }
      .btn-submit {
        background: var(--accent-blue);
        color: white;
        border: none;
        width: 45px;
        height: 45px;
        border-radius: 50%;
        cursor: pointer;
      }
      /* Cấu hình layout cho hàng cài đặt */
      .settings-row {
        display: flex;
        gap: 20px;
        margin-top: 20px;
        margin-bottom: 20px;
        padding: 0 10px;
        align-items: flex-end;
      }

      .setting-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .setting-label {
        font-size: 13px;
        color: var(--text-dim, #9aa0a6);
      }

      /* Wrapper để tuỳ chỉnh mũi tên của Select */
      .select-wrapper {
        position: relative;
        display: inline-block;
      }

      /* Định dạng cho ô Select */
      .custom-select {
        appearance: none; /* Ẩn mũi tên mặc định của trình duyệt */
        -webkit-appearance: none;
        -moz-appearance: none;
        background-color: var(--card-bg, #1e2124);
        color: var(--text-main, #e2e2e2);
        border: 1px solid var(--border-color, #33373b);
        border-radius: 6px;
        padding: 10px 36px 10px 12px;
        font-size: 14px;
        font-family: inherit;
        cursor: pointer;
        outline: none;
        transition: border-color 0.2s ease;
        min-width: 140px;
      }

      /* Hiệu ứng viền màu xanh ngọc khi được chọn giống ảnh */
      .custom-select:focus,
      .custom-select:active {
        border-color: #00bfa5; /* Màu xanh ngọc của Veo */
      }

      /* Tạo lại mũi tên thả xuống (Dropdown Arrow) */
      .select-wrapper::after {
        content: "expand_more";
        font-family: "Material Symbols Outlined";
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-dim, #9aa0a6);
        pointer-events: none; /* Để click không bị vướng */
        font-size: 18px;
      }

      /* Style cho các tuỳ chọn (Option) khi xổ xuống */
      .custom-select option {
        background-color: var(--card-bg, #1e2124);
        color: var(--text-main, #e2e2e2);
        padding: 10px;
      }
      .navbar {
        width: 100%;
        padding: 12px 25px;
        display: flex;
        align-items: center;
        border-radius: 10px 10px 0 0;
      }

      /* Logo */
      .navbar-brand {
        font-size: 20px;
        font-weight: bold;
        color: white;
        margin-right: 30px;
      }

      /* Menu */
      .navbar-nav {
        display: flex;
        gap: 20px;
      }

      /* Link */
      .navbar-nav a {
        text-decoration: none;
        color: #c9d1d9;
        font-size: 15px;
        padding: 6px 10px;
        border-radius: 6px;
        transition: all 0.2s ease;
      }

      @media (max-width: 640px) {
        body {
          padding: 12px;
        }

        .navbar {
          flex-wrap: wrap;
          gap: 8px;
          padding: 10px 12px;
        }

        .navbar-brand {
          margin-right: 0;
          font-size: 17px;
        }

        .navbar-nav {
          flex-wrap: wrap;
          gap: 4px;
        }

        .navbar-nav a {
          font-size: 12px;
          padding: 4px 7px;
        }

        .bulk-header {
          flex-wrap: wrap;
          gap: 10px;
          padding: 0;
        }

        .header-controls {
          flex-wrap: wrap;
          gap: 8px;
        }

        .images-container {
          flex-direction: column;
          align-items: stretch;
        }

        .arrow-sep {
          transform: rotate(90deg);
          align-self: center;
        }

        .thumbnail {
          width: 100%;
          height: auto;
          aspect-ratio: 16 / 9;
        }

        .image-box {
          width: 100%;
        }

        .prompt-area {
          width: 100%;
          box-sizing: border-box;
          height: 90px;
        }

        .settings-row {
          flex-wrap: wrap;
          gap: 12px;
          padding: 0;
        }

        .custom-select {
          min-width: unset;
          width: 100%;
        }

        .frame-group {
          padding: 14px;
        }
      }
    </style>
  </head>
  <body>
    <div class="container hide-end" id="mainApp">
      <nav class="navbar">
        <div class="navbar-brand">API Tool</div>

        <div class="navbar-nav">
          <a href="/">Home</a>
          <a href="/api">Text To Video</a>
          <a href="/api/gemini">Gemini</a>
          <a href="/api/imageToVideo">Image To Video</a>
          <a href="/api/IngredientsToVideo">Ingredients To Video</a>
        </div>
      </nav>

      <form
        id="renderForm"
        action="/api/imageToVideo"
        method="POST"
        enctype="multipart/form-data"
      >
        <div class="bulk-header">
          <div class="header-controls">
            <span>Cấu hình luồng Flow</span>
            <button
              type="button"
              class="btn-toggle-end"
              onclick="toggleEndFrames()"
            >
              <span class="material-symbols-outlined" style="font-size: 18px"
                >visibility_off</span
              >
              Ẩn/Hiện End Frame
            </button>
          </div>
          <button type="button" class="btn-clear" onclick="clearAll()">
            <span class="material-symbols-outlined">delete_sweep</span> Xóa tất
            cả
          </button>
        </div>

        <div id="flowList">
          <div class="frame-group" data-index="0">
            <div class="images-container">
              <div class="image-box">
                <span>Start Frame</span>
                <img
                  src="https://cdn-media.sforum.vn/storage/app/media/ctvseo_maihue/hinh-nen-1920-1080/hinh-nen-1920-1080-thumbnail.jpg"
                  class="thumbnail"
                  onclick="triggerUpload(this)"
                  style="cursor: pointer"
                />
                <input
                  type="file"
                  name="start_images[0]"
                  accept="image/*"
                  style="display: none"
                  onchange="previewImage(this)"
                />
              </div>

              <span class="material-symbols-outlined arrow-sep">sync_alt</span>

              <div class="image-box end-frame-box">
                <span>End Frame</span>
                <img
                  src="https://cdn-media.sforum.vn/storage/app/media/thunguyen/hinh-nen-vui-ve-2.jpg"
                  class="thumbnail"
                  onclick="triggerUpload(this)"
                  style="cursor: pointer"
                />
                <input
                  type="file"
                  name="end_images[0]"
                  accept="image/*"
                  style="display: none"
                  onchange="previewImage(this)"
                />
              </div>

              <textarea
                name="prompts[0]"
                class="prompt-area"
                placeholder="Nhập prompt..."
              ></textarea>
            </div>
          </div>
        </div>

        <div class="add-row">
          <button type="button" class="btn-add-frame" onclick="addFullFrame()">
            <span class="material-symbols-outlined">add</span>
          </button>
        </div>
        <div class="settings-row">
          <div class="setting-group">
            <label class="setting-label">Tỉ lệ khung hình:</label>
            <div class="select-wrapper">
              <select name="aspectRatio" class="custom-select">
                <option value="16:9" selected>Ngang</option>
                <option value="9:16">Dọc</option>
              </select>
            </div>
          </div>

          <div class="setting-group">
            <label class="setting-label">Model:</label>
            <div class="select-wrapper">
              <select name="modelType" class="custom-select">
                <option value="Veo 3.1 - Fast" selected>Veo 3.1 - Fast</option>

                <option value="Veo 3.1 - Quality">Veo 3.1 - Quality</option>
              </select>
            </div>
          </div>
        </div>
        <div class="footer">
          <button type="submit" class="btn-submit">
            <span class="material-symbols-outlined">arrow_forward</span>
          </button>
        </div>
      </form>
    </div>
    <script>
      function toggleEndFrames() {
        const app = document.getElementById("mainApp");
        app.classList.toggle("hide-end");
      }

      function reindexFrames() {
        document.querySelectorAll("#flowList .frame-group").forEach((group, i) => {
          group.dataset.index = i;
          const startInput = group.querySelector('input[name^="start_images"]');
          const endInput = group.querySelector('input[name^="end_images"]');
          const textarea = group.querySelector("textarea");
          if (startInput) startInput.name = `start_images[${i}]`;
          if (endInput) endInput.name = `end_images[${i}]`;
          if (textarea) textarea.name = `prompts[${i}]`;
        });
      }

      function addFullFrame() {
        const list = document.getElementById("flowList");
        const idx = list.querySelectorAll(".frame-group").length;
        const frameHTML = `
          <div class="frame-group extra-frame" data-index="${idx}">
            <button class="btn-delete" onclick="this.closest('.frame-group').remove(); reindexFrames();"><span class="material-symbols-outlined">close</span></button>
            <div class="images-container">
              <div class="image-box">
                <span>Start Frame</span>
                <img src="https://cdn-media.sforum.vn/storage/app/media/ctvseo_maihue/hinh-nen-1920-1080/hinh-nen-1920-1080-thumbnail.jpg" class="thumbnail" onclick="triggerUpload(this)" style="cursor:pointer"/>
                <input type="file" name="start_images[${idx}]" accept="image/*" style="display:none" onchange="previewImage(this)"/>
              </div>
              <span class="material-symbols-outlined arrow-sep">sync_alt</span>
              <div class="image-box end-frame-box">
                <span>End Frame</span>
                <img src="https://cdn-media.sforum.vn/storage/app/media/thunguyen/hinh-nen-vui-ve-2.jpg" class="thumbnail" onclick="triggerUpload(this)" style="cursor:pointer"/>
                <input type="file" name="end_images[${idx}]" accept="image/*" style="display:none" onchange="previewImage(this)"/>
              </div>
              <textarea name="prompts[${idx}]" class="prompt-area" placeholder="Nhập prompt..."></textarea>
            </div>
          </div>`;
        list.insertAdjacentHTML("beforeend", frameHTML);
      }

      function clearAll() {
        document.querySelectorAll(".extra-frame").forEach((el) => el.remove());
        reindexFrames();
      }
      function triggerUpload(img) {
        img.nextElementSibling.click();
      }
      function previewImage(input) {
        if (input.files && input.files[0]) {
          const reader = new FileReader();
          reader.onload = (e) => { input.previousElementSibling.src = e.target.result; };
          reader.readAsDataURL(input.files[0]);
        }
      }
    </script>
  </body>
</html>
