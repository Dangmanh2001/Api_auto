<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Google Flow - Ingredients</title>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,400,0,0"
    />
    <style>
      :root {
        --bg-dark: #131517;
        --card-bg: #1e2124;
        --border-color: #33373b;
        --text-main: #e2e2e2;
        --text-dim: #9aa0a6;
        --accent-blue: #4d94ff;
      }

      body {
        background-color: var(--bg-dark);
        color: var(--text-main);
        font-family: "Segoe UI", sans-serif;
        padding: 40px;
        margin: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        box-sizing: border-box;
      }

      .container {
        max-width: 600px;
        width: 100%;
      }

      .container-fluid {
        max-width: 600px;
        width: 100%;
        box-sizing: border-box;
      }

      /* Khối Ingredient chính */
      .ingredient-card {
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 16px;
        position: relative;
      }

      .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
      }

      .card-title {
        font-size: 14px;
        font-weight: 600;
        color: #fff;
      }

      .header-icons {
        display: flex;
        gap: 10px;
        color: var(--text-dim);
      }

      .btn-icon {
        cursor: pointer;
        font-size: 18px !important;
      }

      .btn-icon:hover {
        color: #fff;
      }

      /* Vùng upload ảnh */
      .upload-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 15px;
      }

      .upload-box {
        position: relative; /* Bắt buộc để ảnh preview đè lên */
        aspect-ratio: 16 / 9; /* Đổi thành tỷ lệ 16:9 cho Landscape */
        overflow: hidden; /* Để ảnh không tràn góc bo tròn */
        border: 1px dashed var(--border-color);
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        color: var(--text-dim);
        cursor: pointer;
        font-size: 12px;
        transition: 0.2s;
      }
      .preview-img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover; /* Để ảnh phủ kín box */
        border-radius: 8px;
        z-index: 10; /* Để ảnh đè lên trên icon/chữ */
      }

      .upload-box:hover {
        border-color: var(--accent-blue);
        background: rgba(77, 148, 255, 0.05);
      }

      .upload-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 8px;
      }

      /* Textarea nhập prompt */
      .prompt-box {
        width: 100%;
        background-color: transparent;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 12px;
        color: var(--text-main);
        font-size: 13px;
        resize: none;
        box-sizing: border-box;
        outline: none;
      }

      /* Nút thêm Ingredient */
      .btn-add-wrapper {
        border: 1px dashed var(--border-color);
        border-radius: 12px;
        padding: 30px;
        text-align: center;
        cursor: pointer;
        color: var(--text-dim);
        transition: 0.2s;
      }

      .btn-add-wrapper:hover {
        border-color: var(--accent-blue);
        color: #fff;
      }

      .footer-action {
        margin-top: 20px;
      }

      .btn-start {
        background: #fff;
        color: #000;
        border: none;
        padding: 10px 24px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
      }
      .navbar {
        width: 100%;
        padding: 12px 25px;
        display: flex;
        align-items: center;
        border-radius: 10px 10px 0 0;
      }

      /* Logo */
      .navbar-brand {
        font-size: 20px;
        font-weight: bold;
        color: white;
        margin-right: 30px;
      }

      /* Menu */
      .navbar-nav {
        display: flex;
        gap: 20px;
      }

      /* Link */
      .navbar-nav a {
        text-decoration: none;
        color: #c9d1d9;
        font-size: 15px;
        padding: 6px 10px;
        border-radius: 6px;
        transition: all 0.2s ease;
      }
      /* Cấu hình layout cho hàng cài đặt */
      .settings-row {
        display: flex;
        gap: 20px;
        margin-top: 20px;
        margin-bottom: 20px;
        padding: 0 10px;
        align-items: flex-end;
      }

      .setting-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .setting-label {
        font-size: 13px;
        color: var(--text-dim, #9aa0a6);
      }

      /* Wrapper để tuỳ chỉnh mũi tên của Select */
      .select-wrapper {
        position: relative;
        display: inline-block;
      }
      .custom-select {
        appearance: none; /* Ẩn mũi tên mặc định của trình duyệt */
        -webkit-appearance: none;
        -moz-appearance: none;
        background-color: var(--card-bg, #1e2124);
        color: var(--text-main, #e2e2e2);
        border: 1px solid var(--border-color, #33373b);
        border-radius: 6px;
        padding: 10px 36px 10px 12px;
        font-size: 14px;
        font-family: inherit;
        cursor: pointer;
        outline: none;
        transition: border-color 0.2s ease;
        min-width: 140px;
      }

      /* Hiệu ứng viền màu xanh ngọc khi được chọn giống ảnh */
      .custom-select:focus,
      .custom-select:active {
        border-color: #00bfa5; /* Màu xanh ngọc của Veo */
      }

      /* Tạo lại mũi tên thả xuống (Dropdown Arrow) */
      .select-wrapper::after {
        content: "expand_more";
        font-family: "Material Symbols Outlined";
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-dim, #9aa0a6);
        pointer-events: none; /* Để click không bị vướng */
        font-size: 18px;
      }

      /* Style cho các tuỳ chọn (Option) khi xổ xuống */
      .custom-select option {
        background-color: var(--card-bg, #1e2124);
        color: var(--text-main, #e2e2e2);
        padding: 10px;
      }

      @media (max-width: 640px) {
        body {
          padding: 12px;
        }

        .container-fluid {
          padding: 0;
        }

        .navbar {
          flex-wrap: wrap;
          gap: 8px;
          padding: 10px 12px;
        }

        .navbar-brand {
          margin-right: 0;
          font-size: 17px;
        }

        .navbar-nav {
          flex-wrap: wrap;
          gap: 4px;
        }

        .navbar-nav a {
          font-size: 12px;
          padding: 4px 7px;
        }

        .upload-row {
          grid-template-columns: repeat(2, 1fr);
        }

        .settings-row {
          flex-wrap: wrap;
          gap: 12px;
          padding: 0;
        }

        .custom-select {
          min-width: unset;
          width: 100%;
        }

        .ingredient-card {
          padding: 14px;
        }

        .prompt-box {
          font-size: 14px;
        }
      }
    </style>
  </head>
  <body>
    <div class="container-fluid">
      <nav class="navbar">
        <div class="navbar-brand">API Tool</div>

        <div class="navbar-nav">
          <a href="/">Home</a>
          <a href="/api">Text To Video</a>
          <a href="/api/gemini">Gemini</a>
          <a href="/api/imageToVideo">Image To Video</a>
          <a href="/api/IngredientsToVideo">Ingredients To Video</a>
        </div>
      </nav>

      <form
        id="renderForm"
        action="/api/IngredientsToVideo"
        method="POST"
        enctype="multipart/form-data"
      >
        <div id="ingredientList">
          <div class="ingredient-card">
            <div class="card-header">
              <span class="card-title">Ingredient 1</span>
              <div class="header-icons">
                <span
                  class="material-symbols-outlined btn-icon btn-delete"
                  onclick="removeIngredient(this)"
                  >close</span
                >
              </div>
            </div>

            <div class="upload-row">
              <div
                class="upload-box"
                onclick="this.querySelector('input').click()"
              >
                <span class="material-symbols-outlined">upload</span>
                <span>Upload</span>
                <input
                  type="file"
                  name="images_1[]"
                  hidden
                  onchange="handlePreview(this)"
                />
              </div>
              <div
                class="upload-box"
                onclick="this.querySelector('input').click()"
              >
                <span class="material-symbols-outlined">upload</span>
                <span>Upload</span>
                <input
                  type="file"
                  name="images_1[]"
                  hidden
                  onchange="handlePreview(this)"
                />
              </div>
              <div
                class="upload-box"
                onclick="this.querySelector('input').click()"
              >
                <span class="material-symbols-outlined">upload</span>
                <span>Upload</span>
                <input
                  type="file"
                  name="images_1[]"
                  hidden
                  onchange="handlePreview(this)"
                />
              </div>
            </div>

            <textarea
              name="prompts[]"
              class="prompt-box"
              rows="3"
              placeholder="Nhập prompt cho ingredient này..."
            ></textarea>
          </div>
        </div>

        <div class="btn-add-wrapper" onclick="addIngredient()">
          <span
            class="material-symbols-outlined"
            style="font-size: 32px; display: block; margin-bottom: 10px"
            >add</span
          >
          <span>Thêm Ingredient</span>
        </div>

        <div class="footer-action">
          <button type="submit" class="btn-start">Bắt đầu</button>
        </div>
        <div class="settings-row">
          <div class="setting-group">
            <label class="setting-label">Tỉ lệ khung hình:</label>
            <div class="select-wrapper">
              <select name="aspectRatio" class="custom-select">
                <option value="16:9" selected>Ngang</option>
                <option value="9:16">Dọc</option>
              </select>
            </div>
          </div>

          <div class="setting-group">
            <label class="setting-label">Model:</label>
            <div class="select-wrapper">
              <select name="modelType" class="custom-select">
                <option value="Veo 3.1 - Fast [Lower Priority]" selected>
                  Veo 3.1 - Fast [Lower Priority]
                </option>
                <option value="Veo 3.1 - Lite">Veo 3.1 - Lite</option>
                <option value="Veo 3.1 - Creative">Veo 3.1 - Creative</option>
                <option value="Veo 3.1 - Stylized">Veo 3.1 - Stylized</option>
              </select>
            </div>
          </div>
        </div>
      </form>
    </div>

    <script>
      let count = 1;

      function addIngredient() {
        count++;
        const list = document.getElementById("ingredientList");
        const newCard = document.createElement("div");
        newCard.className = "ingredient-card";
        newCard.innerHTML = `
                <div class="card-header">
                    <span class="card-title">Ingredient ${count}</span>
                    <div class="header-icons">
                        <span class="material-symbols-outlined btn-icon" onclick="removeIngredient(this)">close</span>
                    </div>
                </div>
                <div class="upload-row">
                    ${Array(3)
                      .fill(
                        `<div class="upload-box" onclick="this.querySelector('input').click()">
                        <span class="material-symbols-outlined">upload</span>
                        <span>Upload</span>
                        <input type="file" name="images_${count}[]" hidden onchange="handlePreview(this)">
                    </div>`,
                      )
                      .join("")}
                </div>
                <textarea name="prompts[]" class="prompt-box" rows="3" placeholder="Nhập prompt cho ingredient này..."></textarea>
            `;
        list.appendChild(newCard);
      }

      function removeIngredient(btn) {
        const cards = document.querySelectorAll(".ingredient-card");
        if (cards.length > 1) {
          btn.closest(".ingredient-card").remove();
          reindexIngredients(); // Quan trọng: Đánh số lại sau khi xóa
        } else {
          alert("Phải có ít nhất một Ingredient!");
        }
      }
      function reindexIngredients() {
        const cards = document.querySelectorAll(".ingredient-card");
        cards.forEach((card, index) => {
          const displayIndex = index + 1;
          // Cập nhật tiêu đề hiển thị (Ingredient 1, 2, 3...)
          const title = card.querySelector(".card-title");
          title.innerText = `Ingredient ${displayIndex}`;

          // Cập nhật thuộc tính name của các input file nếu bạn cần phân biệt theo dòng
          // Nếu dùng images[] chung cho tất cả thì không cần bước này,
          // nhưng nếu muốn phân tách theo cụm thì dùng:
          const inputs = card.querySelectorAll('input[type="file"]');
          inputs.forEach((input) => {
            input.name = `images_${displayIndex}[]`;
          });
        });
      }
      function handlePreview(input) {
        if (input.files && input.files[0]) {
          const reader = new FileReader();
          const box = input.parentElement; // Đây là thẻ .upload-box

          reader.onload = function (e) {
            // 1. Kiểm tra xem đã có thẻ img preview chưa, nếu chưa thì tạo mới
            let img = box.querySelector(".preview-img");
            if (!img) {
              img = document.createElement("img");
              img.className = "preview-img";
              box.appendChild(img);
            }

            // 2. Gán dữ liệu ảnh vào thẻ img
            img.src = e.target.result;

            // 3. Ẩn các icon và chữ "Upload" hiện có
            box.querySelectorAll("span").forEach((span) => {
              span.style.visibility = "hidden"; // Dùng visibility:hidden để giữ nguyên layout
            });

            // 4. Quan trọng nhất: Giữ nguyên thẻ input nhưng ẩn nó đi
            // Đừng xóa nó, đừng thay đổi innerHTML của box
            // Thẻ input vẫn nằm đó để gửi file lên server
            input.style.position = "absolute";
            input.style.opacity = "0";
            input.style.zIndex = "11"; // Để người dùng vẫn có thể click lại nếu muốn đổi ảnh
          };

          reader.readAsDataURL(input.files[0]);
        }
      }
    </script>
  </body>
</html>
